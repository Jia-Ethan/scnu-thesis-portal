APP_ENV=production
PUBLIC_DOMAIN=thesis.example.cn
ACME_EMAIL=admin@example.cn

POSTGRES_USER=scnu
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=scnu_thesis

SCNU_ACCESS_CODE=replace-with-private-access-code
SCNU_SECRET_KEY=replace-with-64-plus-random-characters
SCNU_STORAGE_DIR=/data/storage

MAX_DOCX_SIZE_BYTES=20971520
MAX_TEXT_PRECHECK_CHARS=80000
PUBLIC_EXPORT_RETENTION_SECONDS=1800
PUBLIC_EXPORT_RATE_LIMIT_PER_HOUR=10

TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-cloudflare-turnstile-secret-key
VITE_TURNSTILE_SITE_KEY=replace-with-cloudflare-turnstile-site-key
