# SCNU Workbench / exporter
APP_ENV=development
MAX_DOCX_SIZE_BYTES=20971520
MAX_TEXT_PRECHECK_CHARS=80000
PUBLIC_EXPORT_RETENTION_SECONDS=1800
PUBLIC_EXPORT_RATE_LIMIT_PER_HOUR=10
SCNU_DATABASE_URL=
SCNU_STORAGE_DIR=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=

# Optional private deployment gate.
SCNU_ACCESS_CODE=

# Required for real deployments that save Provider API keys.
SCNU_SECRET_KEY=

# Legacy Story2Paper experiment settings.
OUTPUT_DIR=./output
LITELLM_API_KEY=***
CORS_ORIGINS=http://localhost:3000
PAPER_DB_PATH=/data/papers.db
